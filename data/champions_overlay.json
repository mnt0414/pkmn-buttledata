  "abilities": {
    "うなぎのぼり": {
      "effect": "特性 ふゆう と ビーストブースト の効果をあわせ持つ。具体的には、 タイプの技を受けず、また技 どくびし 、 まきびし 、 ねばねばネット や特性 ありじごく の効果を受けない。 エレキフィールド 、 サイコフィールド 、 グラスフィールド 、 ミストフィールド の効果も受けない。また、さらに、自分の技で相手を倒すと、自分の最も高い能力の能力ランクが1段階上がる。"
    },
    "かんつうドリル": {
      "effect": "接触技(直接攻撃)を使うと、相手の まもる 、 みきり 、 たたみがえし 、 トーチカ 、 キングシールド 、 ニードルガード 、 ブロッキング 、 スレッドトラップ 、 かえんのまもり 、 ファストガード 、 ワイドガード の守りの効果を無視して、本来の1/4のダメージを与える。相手の守りの効果以外は発動される。"
    },
    "とびだすハバネロ": {
      "effect": "技のダメージを受けると、相手を『やけど』状態にする。"
    },
    "ドラゴンスキン": {
      "effect": "自分の タイプの技が タイプになり、さらに威力が1.2倍になる。(ダイマックスすると、 ダイドラグーン になるが、威力の補正はない。)",
      "fromType": "ノーマル",
      "toType": "ドラゴン",
      "mult": 1.2
    },
    "ほのおのたてがみ": {
      "effect": "タイプの技の威力が1.5倍になる。",
      "type": "ほのお",
      "mult": 1.5
    },
    "メガソーラー": {
      "effect": "自分が技を使った時だけ、実際の天気に関係なく、天気が にほんばれ 状態の時と同じ効果になる。(天気が変わるわけではない)",
      "weather": "sun",
      "applyOnAttackOnly": true,
      "note": "自分が技を使う時だけ天気=にほんばれ扱い"
    }
  },
